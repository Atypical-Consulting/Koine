{
  "name": "koine",
  "displayName": "Koine",
  "description": "Syntax highlighting and live diagnostics for the Koine DDD language (.koi).",
  "version": "0.3.0",
  "publisher": "atypical-consulting",
  "icon": "assets/icon.png",
  "engines": { "vscode": "^1.75.0" },
  "categories": ["Programming Languages", "Linters"],
  "keywords": ["koine", "ddd", "domain-driven-design", "dsl", "language-server"],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Atypical-Consulting/Koine.git",
    "directory": "tooling/koine-textmate"
  },
  "bugs": {
    "url": "https://github.com/Atypical-Consulting/Koine/issues"
  },
  "main": "./out/extension.js",
  "activationEvents": ["onLanguage:koine"],
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "test:lsp": "node test/lsp-smoke.mjs",
    "package": "vsce package",
    "install-vsce": "npm i -g @vscode/vsce"
  },
  "contributes": {
    "commands": [
      { "command": "koine.previewEmit", "title": "Preview Emitted Code", "category": "Koine" },
      { "command": "koine.showGlossary", "title": "Show Glossary", "category": "Koine" },
      { "command": "koine.showContextMap", "title": "Show Context Map", "category": "Koine" },
      { "command": "koine.checkCompatibility", "title": "Check Compatibility (vs baseline)", "category": "Koine" }
    ],
    "menus": {
      "commandPalette": [
        { "command": "koine.previewEmit", "when": "editorLangId == koine" },
        { "command": "koine.showGlossary", "when": "editorLangId == koine" },
        { "command": "koine.showContextMap", "when": "editorLangId == koine" },
        { "command": "koine.checkCompatibility", "when": "editorLangId == koine" }
      ]
    },
    "languages": [
      {
        "id": "koine",
        "aliases": ["Koine", "koine"],
        "extensions": [".koi"],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "koine",
        "scopeName": "source.koine",
        "path": "./syntaxes/koine.tmLanguage.json"
      }
    ],
    "configuration": {
      "title": "Koine",
      "properties": {
        "koine.server.path": {
          "type": "string",
          "default": "",
          "markdownDescription": "How to launch the Koine language server.\n\n- Leave **empty** to use the `koine` executable on your `PATH` (`koine lsp`).\n- Set to an absolute path of a published `koine` binary (it is invoked as `<path> lsp`).\n- Set to `dotnet` to run the CLI from source — combine with `#koine.server.args#`."
        },
        "koine.server.args": {
          "type": "array",
          "items": { "type": "string" },
          "default": [],
          "markdownDescription": "Extra arguments inserted **before** the `lsp` subcommand. Use this when `#koine.server.path#` is `dotnet`, e.g. `[\"run\", \"--project\", \"src/Koine.Cli\", \"--\"]` or `[\"/abs/path/Koine.Cli.dll\"]`."
        },
        "koine.trace.server": {
          "type": "string",
          "enum": ["off", "messages", "verbose"],
          "default": "off",
          "description": "Traces the communication between VS Code and the Koine language server."
        }
      }
    }
  },
  "dependencies": {
    "vscode-languageclient": "^10.0.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/vscode": "^1.75.0",
    "typescript": "^6.0.0"
  }
}
