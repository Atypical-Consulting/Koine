{
  "name": "koine",
  "displayName": "Koine",
  "description": "Syntax highlighting and live diagnostics for the Koine DDD language (.koi).",
  "version": "0.3.0",
  "publisher": "atypical-consulting",
  "icon": "assets/icon.png",
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Programming Languages",
    "Linters"
  ],
  "keywords": [
    "koine",
    "ddd",
    "domain-driven-design",
    "dsl",
    "language-server"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Atypical-Consulting/Koine.git",
    "directory": "tooling/koine-textmate"
  },
  "bugs": {
    "url": "https://github.com/Atypical-Consulting/Koine/issues"
  },
  "main": "./out/extension.js",
  "activationEvents": [
    "onLanguage:koine"
  ],
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "test:lsp": "node test/lsp-smoke.mjs",
    "package": "vsce package",
    "install-vsce": "npm i -g @vscode/vsce"
  },
  "contributes": {
    "commands": [
      {
        "command": "koine.previewEmit",
        "title": "Preview Emitted Code",
        "category": "Koine"
      },
      {
        "command": "koine.showGlossary",
        "title": "Show Glossary",
        "category": "Koine"
      },
      {
        "command": "koine.showContextMap",
        "title": "Show Context Map",
        "category": "Koine"
      },
      {
        "command": "koine.checkCompatibility",
        "title": "Check Compatibility (vs baseline)",
        "category": "Koine"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "koine.previewEmit",
          "when": "editorLangId == koine"
        },
        {
          "command": "koine.showGlossary",
          "when": "editorLangId == koine"
        },
        {
          "command": "koine.showContextMap",
          "when": "editorLangId == koine"
        },
        {
          "command": "koine.checkCompatibility",
          "when": "editorLangId == koine"
        }
      ]
    },
    "languages": [
      {
        "id": "koine",
        "aliases": [
          "Koine",
          "koine"
        ],
        "extensions": [
          ".koi"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "koine",
        "scopeName": "source.koine",
        "path": "./syntaxes/koine.tmLanguage.json"
      }
    ],
    "configuration": {
      "title": "Koine",
      "properties": {
        "koine.server.path": {
          "type": "string",
          "default": "",
          "markdownDescription": "How to launch the Koine language server.\n\n- Leave **empty** to use the `koine` executable on your `PATH` (`koine lsp`).\n- Set to an absolute path of a published `koine` binary (it is invoked as `<path> lsp`).\n- Set to `dotnet` to run the CLI from source — combine with `#koine.server.args#`."
        },
        "koine.server.args": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "markdownDescription": "Extra arguments inserted **before** the `lsp` subcommand. Use this when `#koine.server.path#` is `dotnet`, e.g. `[\"run\", \"--project\", \"src/Koine.Cli\", \"--\"]` or `[\"/abs/path/Koine.Cli.dll\"]`."
        },
        "koine.trace.server": {
          "type": "string",
          "enum": [
            "off",
            "messages",
            "verbose"
          ],
          "default": "off",
          "description": "Traces the communication between VS Code and the Koine language server."
        }
      }
    },
    "semanticTokenModifiers": [
      {
        "id": "aggregate",
        "description": "Aggregate (Concept Colors, ADR 0004)"
      },
      {
        "id": "entity",
        "description": "Entity (Concept Colors, ADR 0004)"
      },
      {
        "id": "valueObject",
        "description": "Value object (Concept Colors, ADR 0004)"
      },
      {
        "id": "enumeration",
        "description": "Enumeration (Concept Colors, ADR 0004)"
      },
      {
        "id": "domainEvent",
        "description": "Domain event (Concept Colors, ADR 0004)"
      },
      {
        "id": "integrationEvent",
        "description": "Integration event (Concept Colors, ADR 0004)"
      },
      {
        "id": "command",
        "description": "Command (Concept Colors, ADR 0004)"
      },
      {
        "id": "query",
        "description": "Query (Concept Colors, ADR 0004)"
      },
      {
        "id": "readModel",
        "description": "Read model (Concept Colors, ADR 0004)"
      },
      {
        "id": "service",
        "description": "Service (Concept Colors, ADR 0004)"
      },
      {
        "id": "repository",
        "description": "Repository (Concept Colors, ADR 0004)"
      },
      {
        "id": "policy",
        "description": "Policy (Concept Colors, ADR 0004)"
      },
      {
        "id": "factory",
        "description": "Factory (Concept Colors, ADR 0004)"
      },
      {
        "id": "stateMachine",
        "description": "State machine (Concept Colors, ADR 0004)"
      },
      {
        "id": "specification",
        "description": "Specification (Concept Colors, ADR 0004)"
      }
    ],
    "semanticTokenScopes": [
      {
        "language": "koine",
        "scopes": {
          "*.aggregate": [
            "entity.name.type.aggregate.koine"
          ],
          "*.entity": [
            "entity.name.type.entity.koine"
          ],
          "*.valueObject": [
            "entity.name.type.value.koine"
          ],
          "*.enumeration": [
            "entity.name.type.enum.koine"
          ],
          "*.domainEvent": [
            "entity.name.type.event.koine"
          ],
          "*.integrationEvent": [
            "entity.name.type.integration-event.koine"
          ],
          "*.command": [
            "entity.name.type.command.koine"
          ],
          "*.query": [
            "entity.name.type.query.koine"
          ],
          "*.readModel": [
            "entity.name.type.read-model.koine"
          ],
          "*.service": [
            "entity.name.type.service.koine"
          ],
          "*.repository": [
            "entity.name.type.repository.koine"
          ],
          "*.policy": [
            "entity.name.type.policy.koine"
          ],
          "*.factory": [
            "entity.name.type.factory.koine"
          ],
          "*.stateMachine": [
            "entity.name.type.state-machine.koine"
          ],
          "*.specification": [
            "entity.name.type.spec.koine"
          ]
        }
      }
    ],
    "configurationDefaults": {
      "editor.semanticTokenColorCustomizations": {
        "enabled": true,
        "rules": {
          "*.aggregate:koine": "#8b87f5",
          "*.entity:koine": "#34d399",
          "*.valueObject:koine": "#5aa9f0",
          "*.enumeration:koine": "#fbbf24",
          "*.domainEvent:koine": "#f472b6",
          "*.integrationEvent:koine": "#2dd4bf",
          "*.command:koine": "#ef4444",
          "*.query:koine": "#38bdf8",
          "*.readModel:koine": "#a3e635",
          "*.service:koine": "#fb923c",
          "*.repository:koine": "#94a3b8",
          "*.policy:koine": "#d946ef",
          "*.factory:koine": "#f59e0b",
          "*.stateMachine:koine": "#06b6d4",
          "*.specification:koine": "#c084fc"
        },
        "[*Light*]": {
          "rules": {
            "*.aggregate:koine": "#4f46e5",
            "*.entity:koine": "#047857",
            "*.valueObject:koine": "#2563eb",
            "*.enumeration:koine": "#b45309",
            "*.domainEvent:koine": "#db2777",
            "*.integrationEvent:koine": "#0f766e",
            "*.command:koine": "#dc2626",
            "*.query:koine": "#0369a1",
            "*.readModel:koine": "#4d7c0f",
            "*.service:koine": "#c2410c",
            "*.repository:koine": "#475569",
            "*.policy:koine": "#a21caf",
            "*.factory:koine": "#a16207",
            "*.stateMachine:koine": "#0e7490",
            "*.specification:koine": "#7c3aed"
          }
        }
      }
    }
  },
  "dependencies": {
    "vscode-languageclient": "^10.0.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/vscode": "^1.75.0",
    "typescript": "^6.0.0"
  }
}
