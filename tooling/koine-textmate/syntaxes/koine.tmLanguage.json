{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Koine",
  "scopeName": "source.koine",
  "fileTypes": ["koi"],
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#regex" },
    { "include": "#annotations" },
    { "include": "#roles" },
    { "include": "#declarations" },
    { "include": "#clauses" },
    { "include": "#keywords" },
    { "include": "#builtin-types" },
    { "include": "#constants" },
    { "include": "#numbers" },
    { "include": "#field" },
    { "include": "#typename" },
    { "include": "#operators" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.documentation.koine",
          "match": "///(?!/).*$"
        },
        {
          "name": "comment.line.double-slash.koine",
          "match": "//.*$"
        },
        {
          "name": "comment.block.koine",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },
    "strings": {
      "name": "string.quoted.double.koine",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        { "name": "constant.character.escape.koine", "match": "\\\\." }
      ]
    },
    "regex": {
      "name": "string.regexp.koine",
      "begin": "(?<=matches)\\s*/",
      "end": "/",
      "patterns": [
        { "name": "constant.character.escape.koine", "match": "\\\\." }
      ]
    },
    "annotations": {
      "match": "(@)([A-Za-z_][A-Za-z0-9_]*)",
      "captures": {
        "1": { "name": "punctuation.definition.annotation.koine" },
        "2": { "name": "storage.modifier.annotation.koine" }
      }
    },
    "roles": {
      "name": "keyword.other.role.koine",
      "match": "\\b(partnership|shared-kernel|customer-supplier|conformist|anti-corruption-layer|open-host|published-language|acl)\\b"
    },
    "declarations": {
      "patterns": [
        {
          "match": "\\b(integration)\\s+(event)\\s+([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": { "name": "storage.type.koine" },
            "2": { "name": "storage.type.koine" },
            "3": { "name": "entity.name.type.koine" }
          }
        },
        {
          "match": "\\b(context|value|quantity|entity|aggregate|enum|event|module|readmodel|query|service)\\s+([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": { "name": "storage.type.koine" },
            "2": { "name": "entity.name.type.koine" }
          }
        },
        {
          "match": "\\b(spec|policy|usecase|operation|command|create|find)\\s+([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": { "name": "storage.type.koine" },
            "2": { "name": "entity.name.function.koine" }
          }
        }
      ]
    },
    "clauses": {
      "patterns": [
        {
          "match": "\\b(identified)\\s+(by)\\s+([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": { "name": "keyword.control.koine" },
            "2": { "name": "keyword.control.koine" },
            "3": { "name": "entity.name.type.koine" }
          }
        },
        {
          "match": "\\b(root)\\s+([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": { "name": "keyword.control.koine" },
            "2": { "name": "entity.name.type.koine" }
          }
        },
        {
          "match": "\\b(as)\\s+(guid|sequence|natural)\\b",
          "captures": {
            "1": { "name": "keyword.control.koine" },
            "2": { "name": "storage.modifier.koine" }
          }
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.koine",
          "match": "\\b(identified|by|root|as|guid|sequence|natural|versioned|version|invariant|requires|emit|on|from|operations|import|publishes|subscribes|when|if|then|else|matches)\\b"
        },
        {
          "name": "storage.type.koine",
          "match": "\\b(contextmap|context|value|quantity|entity|aggregate|enum|event|integration|module|service|spec|policy|repository|readmodel|query|usecase|operation|command|create|states|find)\\b"
        }
      ]
    },
    "builtin-types": {
      "name": "support.type.primitive.koine",
      "match": "\\b(String|Int|Decimal|Bool|Instant|List|Set|Map|Range)\\b"
    },
    "constants": {
      "name": "constant.language.koine",
      "match": "\\b(true|false)\\b"
    },
    "numbers": {
      "name": "constant.numeric.koine",
      "match": "\\b[0-9]+(\\.[0-9]+)?\\b"
    },
    "field": {
      "match": "\\b([a-z_][A-Za-z0-9_]*)\\s*(:)",
      "captures": {
        "1": { "name": "variable.other.property.koine" },
        "2": { "name": "punctuation.separator.koine" }
      }
    },
    "typename": {
      "name": "entity.name.type.koine",
      "match": "\\b[A-Z][A-Za-z0-9_]*\\b"
    },
    "operators": {
      "name": "keyword.operator.koine",
      "match": "(<->|<-|->|=>|\\?\\?|==|!=|<=|>=|&&|\\|\\||[<>+\\-*/!=])"
    }
  }
}
