{
  "name": "@atypical/koine-ui",
  "private": false,
  "version": "0.1.0",
  "type": "module",
  "description": "Framework-free design tokens and Preact UI primitives extracted from Koine Studio.",
  "license": "MIT",
  "types": "./dist/index.d.ts",
  "module": "./dist/index.js",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "sideEffects": [
    "*.css"
  ],
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles.css": "./dist/styles.css"
  },
  "scripts": {
    "gen:colors": "node scripts/gen-concept-colors.mjs",
    "build": "tsc && vite build",
    "prepack": "npm run build",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "storybook": "storybook dev -p 6007",
    "build-storybook": "storybook build"
  },
  "peerDependencies": {
    "preact": "^10"
  },
  "devDependencies": {
    "@storybook/addon-a11y": "^10.4.6",
    "@storybook/preact-vite": "^10.4.6",
    "@testing-library/preact": "^3.2.4",
    "@types/node": "^24.0.0",
    "axe-core": "^4.12.1",
    "happy-dom": "^20.10.6",
    "preact": "^10.24.0",
    "storybook": "^10.4.6",
    "typescript": "~6.0.0",
    "vite": "^8.0.0",
    "vite-plugin-dts": "^5.0.3",
    "vitest": "^4.1.9",
    "vitest-axe": "^0.1.0"
  }
}
