{
  "name": "koine-studio",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "generate:templates": "node scripts/generate-templates.mjs",
    "dev": "cross-env NODE_OPTIONS=--max-http-header-size=65536 vite",
    "predev": "node scripts/generate-templates.mjs",
    "dev:web": "cross-env NODE_OPTIONS=--max-http-header-size=65536 vite --mode web",
    "predev:web": "node scripts/generate-templates.mjs && node scripts/build-wasm.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "build": "tsc && vite build",
    "prebuild": "node scripts/generate-templates.mjs",
    "build:wasm": "node scripts/build-wasm.mjs",
    "build:web": "tsc && vite build --mode web",
    "prebuild:web": "node scripts/generate-templates.mjs && node scripts/build-wasm.mjs",
    "preview": "vite preview",
    "preview:web": "vite preview --mode web",
    "tauri": "tauri",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.105.0",
    "@codemirror/autocomplete": "^6.18.6",
    "@codemirror/commands": "^6.8.1",
    "@codemirror/lang-php": "^6.0.2",
    "@codemirror/language": "^6.11.0",
    "@codemirror/legacy-modes": "^6.5.1",
    "@codemirror/lint": "^6.8.5",
    "@codemirror/search": "^6.5.11",
    "@codemirror/state": "^6.5.2",
    "@codemirror/view": "^6.38.1",
    "@fontsource-variable/archivo": "^5.2.5",
    "@fontsource-variable/hanken-grotesk": "^5.2.5",
    "@fontsource-variable/jetbrains-mono": "^5.2.5",
    "@lezer/highlight": "^1.2.1",
    "@maxgraph/core": "^0.23.0",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2",
    "@tauri-apps/plugin-opener": "^2",
    "jszip": "^3.10.1",
    "mermaid": "^11.4.0",
    "openai": "^6.44.0",
    "preact": "^10.24.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@storybook/addon-a11y": "^10.4.6",
    "@storybook/addon-vitest": "^10.4.6",
    "@storybook/preact-vite": "^10.4.6",
    "@tauri-apps/cli": "^2",
    "@testing-library/preact": "^3.2.4",
    "axe-core": "^4.12.1",
    "cross-env": "^10.0.0",
    "fake-indexeddb": "^6.2.5",
    "happy-dom": "^20.10.6",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.15",
    "sass-embedded": "^1.100.0",
    "storybook": "^10.4.6",
    "typescript": "~6.0.0",
    "vite": "^8.0.0",
    "vitest": "^4.1.9",
    "vitest-axe": "^0.1.0",
    "playwright": "^1.61.1",
    "@vitest/browser-playwright": "^4.1.9",
    "@vitest/coverage-v8": "^4.1.9"
  }
}
