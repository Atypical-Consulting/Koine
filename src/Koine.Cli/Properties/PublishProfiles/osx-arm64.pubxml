<?xml version="1.0" encoding="utf-8"?>
<!--
  Self-contained, single-file publish profile for the LSP sidecar (Apple Silicon).

  Produces a standalone `koine` binary that Koine Studio / the VS Code extension can
  ship and launch as a language server (`koine lsp`) without a .NET runtime installed.

    dotnet publish src/Koine.Cli -p:PublishProfile=osx-arm64

  Notes:
  - The published executable is renamed to `koine` by the `RenamePublishedBinaryToKoine`
    target in Koine.Cli.csproj (it runs AfterTargets="Publish"). The rename is done there,
    NOT via <AssemblyName> here, because Koine.Compiler grants internals access to the
    assembly literally named `Koine.Cli` and the CLI consumes those internals — renaming the
    assembly identity would break that friend relationship and fail the build. The global-tool
    packaging (PackAsTool / ToolCommandName) stays unaffected either way.
  - PublishTrimmed is kept OFF: the compiler and ANTLR rely on reflection, so trimming
    is unsafe and could break parsing/emission at runtime.
-->
<Project>
  <PropertyGroup>
    <Configuration>Release</Configuration>
    <RuntimeIdentifier>osx-arm64</RuntimeIdentifier>
    <SelfContained>true</SelfContained>
    <PublishSingleFile>true</PublishSingleFile>
    <PublishTrimmed>false</PublishTrimmed>
    <IncludeNativeLibrariesForSelfExtract>true</IncludeNativeLibrariesForSelfExtract>
    <PublishDir>bin/publish/osx-arm64</PublishDir>
  </PropertyGroup>
</Project>
