<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <RootNamespace>Koine.Mcp</RootNamespace>
  </PropertyGroup>

  <!-- Pack as an installable dotnet global tool: `dotnet tool install -g Koine.Mcp`
       then register `koine-mcp` as an MCP server. Metadata comes from Directory.Build.props. -->
  <PropertyGroup>
    <PackAsTool>true</PackAsTool>
    <ToolCommandName>koine-mcp</ToolCommandName>
    <PackageId>Koine.Mcp</PackageId>
    <Description>Koine MCP server — exposes the Koine DSL-for-DDD compiler (validate, compile, format) and the language reference to AI agents over the Model Context Protocol (stdio), so an agent can author a complete domain in .koi.</Description>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="ModelContextProtocol" Version="1.4.0" />
    <!-- The Streamable HTTP / SSE server transport (WithHttpTransport + MapMcp) lives in the
         ASP.NET Core companion package; it brings the Microsoft.AspNetCore.App framework reference
         transitively. Only the HTTP host (HttpHost) uses it; the stdio host is unaffected. -->
    <PackageReference Include="ModelContextProtocol.AspNetCore" Version="1.4.0" />
    <!-- Microsoft.Extensions.Hosting (Host.CreateApplicationBuilder, WaitForShutdownAsync) is now
         provided by the Microsoft.AspNetCore.App framework reference below, so it is no longer a
         separate package dependency. -->
  </ItemGroup>

  <!-- Lets HttpHost use WebApplication / Kestrel from a plain (non-Web) SDK console app. Redundant
       with the package above's transitive framework reference, but explicit about the dependency. -->
  <ItemGroup>
    <FrameworkReference Include="Microsoft.AspNetCore.App" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\Koine.Compiler\Koine.Compiler.csproj" />
    <ProjectReference Include="..\Koine.Emit.All\Koine.Emit.All.csproj" />
  </ItemGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="Koine.Mcp.Tests" />
    <InternalsVisibleTo Include="Koine.Compiler.Tests" />
    <!-- The koine CLI hosts the MCP server in-process; it needs the typed HttpHost entry point
         RunAsync(host, port), DefaultHost, and the port-range guard, which stay internal. -->
    <InternalsVisibleTo Include="Koine.Cli" />
  </ItemGroup>

  <!-- Knowledge surfaced to agents. The reference cheatsheet lives in-project; the example
       models are linked from the repo's real examples/demo so they never drift. All are embedded
       (read via the assembly manifest in KnowledgeStore) so the packaged tool is self-contained.
       Explicit LogicalName keeps resource names stable regardless of on-disk location. -->
  <ItemGroup>
    <EmbeddedResource Include="..\..\templates\pizzeria\menu.koi">
      <LogicalName>koine.examples.pizzeria-menu.koi</LogicalName>
      <Link>Models\menu.koi</Link>
    </EmbeddedResource>
    <EmbeddedResource Include="..\..\templates\pizzeria\context-map.koi">
      <LogicalName>koine.examples.pizzeria-context-map.koi</LogicalName>
      <Link>Models\context-map.koi</Link>
    </EmbeddedResource>
    <EmbeddedResource Include="..\..\templates\pizzeria\ordering.koi">
      <LogicalName>koine.examples.pizzeria-ordering.koi</LogicalName>
      <Link>Models\ordering.koi</Link>
    </EmbeddedResource>
    <EmbeddedResource Include="..\..\templates\pizzeria\kitchen.koi">
      <LogicalName>koine.examples.pizzeria-kitchen.koi</LogicalName>
      <Link>Models\kitchen.koi</Link>
    </EmbeddedResource>
    <EmbeddedResource Include="..\..\templates\pizzeria\delivery.koi">
      <LogicalName>koine.examples.pizzeria-delivery.koi</LogicalName>
      <Link>Models\delivery.koi</Link>
    </EmbeddedResource>
    <EmbeddedResource Include="..\..\templates\pizzeria\payment.koi">
      <LogicalName>koine.examples.pizzeria-payment.koi</LogicalName>
      <Link>Models\payment.koi</Link>
    </EmbeddedResource>
    <EmbeddedResource Include="..\..\templates\pizzeria\promotions.koi">
      <LogicalName>koine.examples.pizzeria-promotions.koi</LogicalName>
      <Link>Models\promotions.koi</Link>
    </EmbeddedResource>
    <EmbeddedResource Include="..\..\templates\starters\billing\billing.koi">
      <LogicalName>koine.examples.billing.koi</LogicalName>
      <Link>Models\billing.koi</Link>
    </EmbeddedResource>
    <EmbeddedResource Include="Knowledge\reference.md" LogicalName="koine.reference.md" />
  </ItemGroup>

</Project>
