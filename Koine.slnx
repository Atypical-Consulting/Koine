<Solution>
  <Folder Name="/.github/">
    <File Path=".github/workflows/ci.yml" />
    <File Path=".github/workflows/release.yml" />
    <File Path=".github/workflows/deploy-docs.yml" />
    <File Path=".github/PULL_REQUEST_TEMPLATE.md" />
    <File Path=".github/ISSUE_TEMPLATE/bug_report.yml" />
    <File Path=".github/ISSUE_TEMPLATE/feature_request.yml" />
    <File Path=".github/ISSUE_TEMPLATE/config.yml" />
  </Folder>
  <Folder Name="/src/">
    <Project Path="src/Koine.Cli/Koine.Cli.csproj" />
    <Project Path="src/Koine.Compiler/Koine.Compiler.csproj" />
    <Project Path="src/Koine.Compiler.SourceGen/Koine.Compiler.SourceGen.csproj" />
    <!-- Koine.Wasm is intentionally NOT in the solution: it targets the browser-wasm RID and
         needs the wasm-experimental workload + emscripten, which the CI build/test pipeline
         (ci.yml) doesn't install. It's built standalone by website/scripts/build-wasm.mjs in
         the docs pipeline (deploy-docs.yml). -->
  </Folder>
  <Folder Name="/tests/">
    <Project Path="tests/Koine.Compiler.Tests/Koine.Compiler.Tests.csproj" />
  </Folder>
  <Folder Name="/benchmarks/">
    <Project Path="benchmarks/Koine.Compiler.Benchmarks/Koine.Compiler.Benchmarks.csproj" />
  </Folder>
  <Folder Name="/demo/">
    <Project Path="demo/Shop.Domain/Shop.Domain.csproj" />
  </Folder>
  <Folder Name="/_docs/">
    <File Path="BRIEF.md" />
    <File Path="CHANGELOG.md" />
    <File Path="CLAUDE.md" />
    <File Path="CODE_OF_CONDUCT.md" />
    <File Path="CONTRIBUTING.md" />
    <File Path="LICENSE" />
    <File Path="NOTICE" />
    <File Path="README.md" />
    <File Path="SECURITY.md" />
    <File Path="USER-STORIES.md" />
  </Folder>
  <Folder Name="/_solution-items/">
    <File Path=".editorconfig" />
    <File Path=".gitignore" />
    <File Path="build.cmd" />
    <File Path="build.ps1" />
    <File Path="build.sh" />
    <File Path="Directory.Build.props" />
    <File Path="renovate.json" />
  </Folder>
</Solution>
