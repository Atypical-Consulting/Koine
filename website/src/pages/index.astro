---
import BlueprintLayout from '../layouts/BlueprintLayout.astro';
import Playground from '../components/Playground.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

import { sampleById } from '../playground/samples';
import { encodeCode } from '../playground/encode';

const ordering = sampleById('ordering');
const orderingStudioHref = ordering
  ? `${base}/studio/#model=${encodeCode(ordering.code)}`
  : `${base}/studio/`;

const features = [
  { r: 'R1–R2', title: 'Expressions & shapes', body: 'Conditionals, string ops, collection lambdas, optionals, sets & maps.' },
  { r: 'R3–R4', title: 'Diagnostics & docs', body: 'Stable error codes, multi-error parsing, doc comments → XML + glossary.' },
  { r: 'R5–R7', title: 'Behavior', body: 'Commands mutate state, domain events record intent, state machines guard transitions.' },
  { r: 'R8–R9', title: 'Creation & values', body: 'Named factories, smart enums with data, quantities, ranges.' },
  { r: 'R10', title: 'Specs, services, policies', body: 'Reusable predicates, stateless domain services, reactive policies.' },
  { r: 'R11', title: 'Identity & persistence', body: 'Four identity strategies, repositories, optimistic concurrency.' },
  { r: 'R12', title: 'Application & CQRS', body: 'Unit of work, application services, read models, query handlers.' },
  { r: 'R13–R14', title: 'Strategic design', body: 'Multi-file modules, imports, context maps, integration events, ACL.' },
  { r: 'R15', title: 'Evolution', body: 'Versioning, deprecation, and breaking-change detection.' },
  { r: 'R16–R17', title: 'Targets & tooling', body: 'C# + TypeScript emitters, LSP, formatter, scaffolding, watch.' },
];

const pillars = [
  {
    k: '01',
    title: 'One source of truth',
    body: 'The .koi file is the ubiquitous language. Doc comments, invariants, and the glossary travel with the model — no drift between the docs and the code.',
  },
  {
    k: '02',
    title: 'The whole DDD toolkit',
    body: 'Value objects, entities, aggregates, commands, events, state machines, repositories, CQRS, context maps, versioning — tactical and strategic, all shipped.',
  },
  {
    k: '03',
    title: 'A green build proves the domain',
    body: 'Every emitted type is snapshot- and compile-tested. The output is idiomatic, dependency-free C# you can read, review, and check into git.',
  },
];
---

<BlueprintLayout
  title="Koine — model the domain, compile the code"
  description="Koine is a DSL for Domain-Driven Design: write the ubiquitous language once in .koi files and generate idiomatic, self-contained C# (and TypeScript)."
>
  <!-- Hero -->
  <section class="hero koi-blueprint">
    <div class="hero__inner">
      <div class="hero__copy">
        <p class="eyebrow">Κοινή · the common tongue of your domain</p>
        <h1>Model the domain.<br /><span class="accent">Compile</span> the code.</h1>
        <p class="lede">
          Koine is a domain-specific language for Domain-Driven Design. Describe a bounded context
          in a small, readable DSL — Koine generates the idiomatic, boilerplate-heavy C# for you.
        </p>
        <div class="cta">
          <a class="btn btn--primary" href={`${base}/studio/`}>Open Koine Studio ▸</a>
          <a class="btn" href={`${base}/start/what-is-koine/`}>Get started</a>
        </div>
        <p class="hero__note">No install. The compiler runs in your browser.</p>
      </div>

      <div class="hero__diagram" aria-hidden="true">
        <figure class="chip chip--in">
          <figcaption>model.koi</figcaption>
          <pre><code>{`value Money {
  amount:   Decimal
  currency: Currency
  invariant amount >= 0
}`}</code></pre>
        </figure>
        <div class="arrow">
          <span class="arrow__label">koine build</span>
          <svg viewBox="0 0 120 24" width="120" height="24">
            <line x1="2" y1="12" x2="106" y2="12"></line>
            <polyline points="98,5 112,12 98,19"></polyline>
          </svg>
        </div>
        <figure class="chip chip--out">
          <figcaption>Money.cs</figcaption>
          <pre><code>{`public sealed class Money
  : ValueObject {
  public decimal Amount { get; }
  public Currency Currency { get; }
  // …validating ctor
}`}</code></pre>
        </figure>
      </div>
    </div>
  </section>

  <!-- Live proof -->
  <section class="band">
    <div class="band__head">
      <h2>See it compile — right here</h2>
      <p>Edit the model. It compiles in your browser the moment you stop typing.</p>
    </div>
    <div class="live">
      <Playground />
    </div>
    <p class="band__more">
      Want the full IDE — glossary, context map, hover docs, and go-to-definition, all in the browser?
      <a href={`${base}/studio/`}>Open Koine Studio ▸</a>
    </p>
  </section>

  <!-- Why Koine -->
  <section class="band band--tight">
    <div class="pillars">
      {
        pillars.map((p) => (
          <article class="pillar">
            <span class="pillar__k">{p.k}</span>
            <h3>{p.title}</h3>
            <p>{p.body}</p>
          </article>
        ))
      }
    </div>
  </section>

  <!-- Feature map -->
  <section class="band">
    <div class="band__head">
      <h2>The complete toolkit, R1–R17</h2>
      <p>
        Fifteen releases of tactical and strategic DDD, shipped — see the
        <a href={`${base}/guides/feature-catalogue/`}>full feature catalogue</a>.
      </p>
    </div>
    <div class="grid">
      {
        features.map((f) => (
          <article class="cell">
            <span class="cell__r">{f.r}</span>
            <h3>{f.title}</h3>
            <p>{f.body}</p>
          </article>
        ))
      }
    </div>
  </section>

  <!-- Multi-target teaser -->
  <section class="band band--tight">
    <div class="teaser">
      <div class="teaser__copy">
        <h2>One model, many targets</h2>
        <p>
          The parser and semantic model are strictly target-agnostic. Koine emits idiomatic
          <strong>C#</strong>, <strong>TypeScript</strong>, and <strong>Python</strong> today — flip
          the target in Studio and watch the same model recompile. Rust is on the
          <a href={`${base}/guides/roadmap/`}>roadmap</a>.
        </p>
        <a class="btn btn--primary" href={orderingStudioHref}>Explore the Ordering model in Studio ▸</a>
      </div>
      <div class="teaser__targets">
        <span class="tgt tgt--on">.koi</span>
        <span class="tgt__arrow">→</span>
        <span class="tgt">C#</span>
        <span class="tgt">TypeScript</span>
        <span class="tgt">Python</span>
        <span class="tgt tgt--soon">Rust · soon</span>
      </div>
    </div>
  </section>

  <style>
    .accent { color: var(--koi-accent); }

    /* Hero */
    .hero {
      border-bottom: 1px solid var(--koi-line);
    }
    .hero__inner {
      max-width: var(--koi-maxw);
      margin: 0 auto;
      padding: clamp(2.5rem, 7vw, 5.5rem) clamp(1rem, 4vw, 2.5rem);
      display: grid;
      grid-template-columns: 1.35fr 0.65fr;
      gap: clamp(1.5rem, 4vw, 3.5rem);
      align-items: center;
    }
    @media (max-width: 880px) {
      .hero__inner { grid-template-columns: 1fr; }
    }
    .eyebrow {
      font-family: var(--koi-font-mono);
      font-size: 0.8rem;
      letter-spacing: 0.04em;
      color: var(--koi-muted);
      margin: 0 0 1rem;
    }
    .hero h1 {
      font-family: var(--koi-font-display);
      font-weight: 800;
      font-size: clamp(2.3rem, 5vw, 3.7rem);
      line-height: 1.04;
      letter-spacing: -0.03em;
      margin: 0 0 1.1rem;
      text-wrap: balance;
    }
    /* Keep each line of the headline intact (it already has an explicit <br>). */
    .hero h1 br {
      display: inline;
    }
    .lede {
      font-size: clamp(1.02rem, 1.6vw, 1.22rem);
      line-height: 1.55;
      color: var(--koi-ink-soft);
      max-width: 44ch;
      margin: 0 0 1.8rem;
    }
    .cta { display: flex; gap: 0.8rem; flex-wrap: wrap; }
    .btn {
      display: inline-flex;
      align-items: center;
      font: 600 0.95rem/1 var(--koi-font-body);
      padding: 0.8rem 1.3rem;
      border-radius: var(--koi-radius-sm);
      border: 1px solid var(--koi-line);
      color: var(--koi-fg);
      background: var(--koi-surface);
      text-decoration: none;
      transition: transform 0.12s, box-shadow 0.12s, background 0.12s;
    }
    .btn:hover { transform: translateY(-2px); box-shadow: var(--koi-shadow); }
    .btn--primary {
      background: var(--koi-accent);
      border-color: var(--koi-accent);
      color: var(--koi-on-accent);
    }
    .btn--primary:hover { box-shadow: 0 14px 30px -12px var(--koi-accent); }
    .hero__note { font-size: 0.85rem; color: var(--koi-muted); margin: 1rem 0 0; font-family: var(--koi-font-mono); }

    /* Hero diagram */
    .hero__diagram {
      display: flex;
      flex-direction: column;
      gap: 0.7rem;
      align-items: stretch;
      width: 100%;
      max-width: 360px;
      justify-self: end;
    }
    .chip {
      margin: 0;
      border: 1px solid var(--koi-line);
      border-radius: var(--koi-radius);
      background: var(--koi-surface);
      box-shadow: var(--koi-shadow);
      overflow: hidden;
      animation: rise 0.6s ease both;
    }
    .chip--out { animation-delay: 0.25s; }
    .chip figcaption {
      font: 600 0.7rem/1 var(--koi-font-mono);
      letter-spacing: 0.06em;
      text-transform: uppercase;
      color: var(--koi-muted);
      padding: 0.5rem 0.8rem;
      border-bottom: 1px dashed var(--koi-line-soft);
      background: var(--koi-paper-2);
    }
    .chip pre { margin: 0; padding: 0.8rem 1rem; overflow: auto; }
    .chip code { font: 0.82rem/1.55 var(--koi-font-mono); color: var(--koi-fg); white-space: pre; }
    .arrow {
      display: flex;
      align-items: center;
      gap: 0.6rem;
      justify-content: center;
      color: var(--koi-accent);
    }
    .arrow__label { font: 600 0.72rem/1 var(--koi-font-mono); color: var(--koi-muted); }
    .arrow svg { stroke: var(--koi-accent-2); stroke-width: 2; fill: none; }
    .arrow line { stroke-dasharray: 110; stroke-dashoffset: 110; animation: draw 0.7s ease 0.4s forwards; }
    .arrow polyline { opacity: 0; animation: fade 0.3s ease 1s forwards; }

    @keyframes rise { from { opacity: 0; transform: translateY(14px); } to { opacity: 1; transform: none; } }
    @keyframes draw { to { stroke-dashoffset: 0; } }
    @keyframes fade { to { opacity: 1; } }

    /* Bands */
    .band {
      max-width: var(--koi-maxw);
      margin: 0 auto;
      padding: clamp(2.5rem, 6vw, 4.5rem) clamp(1rem, 4vw, 2.5rem);
    }
    .band--tight { padding-top: 0; }
    .band__head { max-width: 60ch; margin-bottom: 2rem; }
    .band__head h2 {
      font-family: var(--koi-font-display);
      font-size: clamp(1.6rem, 4vw, 2.4rem);
      letter-spacing: -0.02em;
      margin: 0 0 0.5rem;
    }
    .band__head p { color: var(--koi-muted); margin: 0; font-size: 1.05rem; }
    .band__head a { color: var(--koi-accent); }

    .live { height: min(70vh, 620px); display: flex; }
    .live :global(.koi-ide) { flex: 1; }
    .band__more {
      margin: 1.2rem 0 0;
      text-align: center;
      color: var(--koi-muted);
      font-size: 0.98rem;
    }
    .band__more a { color: var(--koi-accent); font-weight: 600; white-space: nowrap; }

    /* Pillars */
    .pillars {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1.2rem;
    }
    @media (max-width: 880px) { .pillars { grid-template-columns: 1fr; } }
    .pillar {
      border: 1px solid var(--koi-line);
      border-top: 3px solid var(--koi-accent);
      border-radius: var(--koi-radius);
      background: var(--koi-surface);
      padding: 1.5rem;
    }
    .pillar__k {
      font: 700 0.8rem/1 var(--koi-font-mono);
      color: var(--koi-accent-2);
    }
    .pillar h3 { font-family: var(--koi-font-display); font-size: 1.25rem; margin: 0.6rem 0 0.5rem; letter-spacing: -0.01em; }
    .pillar p { color: var(--koi-ink-soft); margin: 0; line-height: 1.55; }

    /* Feature grid */
    .grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
      gap: 1px;
      background: var(--koi-line);
      border: 1px solid var(--koi-line);
      border-radius: var(--koi-radius);
      overflow: hidden;
    }
    .cell {
      background: var(--koi-surface);
      padding: 1.2rem 1.3rem;
    }
    .cell__r {
      font: 700 0.72rem/1 var(--koi-font-mono);
      letter-spacing: 0.04em;
      color: var(--koi-accent);
    }
    .cell h3 { font-size: 1.05rem; margin: 0.5rem 0 0.35rem; }
    .cell p { color: var(--koi-muted); margin: 0; font-size: 0.92rem; line-height: 1.5; }

    /* Teaser */
    .teaser {
      display: grid;
      grid-template-columns: 1.2fr 0.8fr;
      gap: 2rem;
      align-items: center;
      border: 1px solid var(--koi-line);
      border-radius: var(--koi-radius);
      background: var(--koi-surface);
      padding: clamp(1.5rem, 4vw, 2.8rem);
    }
    @media (max-width: 880px) { .teaser { grid-template-columns: 1fr; } }
    .teaser__copy h2 { font-family: var(--koi-font-display); font-size: clamp(1.5rem, 3.5vw, 2.1rem); margin: 0 0 0.7rem; letter-spacing: -0.02em; }
    .teaser__copy p { color: var(--koi-ink-soft); line-height: 1.6; margin: 0 0 1.4rem; }
    .teaser__copy p a { color: var(--koi-accent); }
    .teaser__targets {
      display: flex;
      flex-wrap: wrap;
      gap: 0.6rem;
      align-items: center;
      justify-content: center;
    }
    .tgt {
      font: 600 0.9rem/1 var(--koi-font-mono);
      padding: 0.6rem 0.9rem;
      border: 1px solid var(--koi-line);
      border-radius: var(--koi-radius-sm);
      color: var(--koi-ink-soft);
      background: var(--koi-paper-2);
    }
    .tgt--on { background: var(--koi-accent); color: var(--koi-on-accent); border-color: var(--koi-accent); }
    .tgt--soon { color: var(--koi-muted); border-style: dashed; }
    .tgt__arrow { color: var(--koi-accent-2); font-weight: 700; }
  </style>
</BlueprintLayout>
